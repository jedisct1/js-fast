{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noEmit": true,
		"skipLibCheck": true,
		"types": ["bun-types"],
		"outDir": "dist",
		"rootDir": ".",
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true
	},
	"include": ["src/**/*.ts", "test/**/*.ts", "scripts/**/*.ts"]
}
